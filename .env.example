# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TMDB API Key / Access Token
# Users need to create an account on TMDB and get their API read access token (v4 auth).
VITE_TMDB_ACCESS_TOKEN=

# --- SUBTITLE CONFIGURATION ---

# Subdl API Key (OPTIONAL — Subdl free tier works without a key)
# Get one at: https://subdl.com/setting/api
# Leave blank to use the free tier (may be rate-limited for heavy usage).
VITE_SUBDL_API_KEY=

# OpenSubtitles REST API v2 Key (OPTIONAL — used as fallback if Subdl fails)
# Register at: https://www.opensubtitles.com/en/consumers
# Create a consumer and get your API key.
VITE_OPENSUBTITLES_API_KEY=

# Custom Stremio Subtitle Addon URLs (OPTIONAL — comma-separated)
# You can generate a personalized StremioSubMaker URL at https://submaker.elfhosted.com
# and paste the manifest URL here (e.g. VITE_SUBTITLE_ADDONS=https://submaker.elfhosted.com/.../manifest.json)
VITE_SUBTITLE_ADDONS=

# --- CONSUMET CONFIGURATION ---

# Consumet API instance URL.
# Option 1 (easiest): Deploy your own instance on Cloudflare Workers or Render.
# Option 2: Run locally with Docker:
#   docker run -p 4000:3000 riimuru/consumet-api
#   then set: CONSUMET_URL=http://localhost:4000
#
# SERVER-SIDE (Edge Functions) — required for m3u8 proxy + Consumet API calls:
CONSUMET_URL=http://localhost:4000

# CLIENT-SIDE (Vite) — when set, enables Consumet HLS mode in the player.
# If not set, player goes straight to embed iframe fallback (VidNest/VidSrc).
# Set this to the same value as CONSUMET_URL above.
VITE_CONSUMET_URL=http://localhost:4000