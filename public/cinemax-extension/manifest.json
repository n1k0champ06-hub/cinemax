{
  "manifest_version": 3,
  "name": "Cinemax Subtitle Sync",
  "version": "1.1",
  "description": "Đồng bộ phụ đề tiếng Việt chính xác 100% cho Cinemax Player trên các nguồn phát Iframe.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cinemax Subtitle Sync"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "http://localhost/*", "https://localhost/*", "http://127.0.0.1/*", "https://127.0.0.1/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
